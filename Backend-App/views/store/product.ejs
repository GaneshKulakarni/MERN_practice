<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
  </head>
  <body>
    <h1>Products Page</h1>
    <div class="row">
      <% if (product && product.length) { %>
        <% product.forEach(p => { %>
          <div class="box">
            <img src="<%= p.imageUrl %>" width="300px" alt="">
            <h2><%= p.name %></h2>
            <h4>Price:<%= p.price %></h4>
            <p><%= p.Description%></p>
          </div>
        <% }) %>
      <% } else { %>
        <p>No products available yet.</p>
      <% } %>
    </div>
  </body>
</html>